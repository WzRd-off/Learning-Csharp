<Window x:Class="PR3_2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PR3_2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
	
    <Grid>
		<StackPanel>
			<StackPanel Orientation="Horizontal">
				<Button x:Name="btnSelectImage" Content="Оберіть зображення" Click="btnSelectImage_Click"/>
				<Button x:Name="btnShuffle" Content="Перемішати" Click="btnShuffle_Click"/>
				<TextBox x:Name="txtRows" Width="50" Margin="5" Text="3"/>
				<TextBox x:Name="txtColumns" Width="50" Margin="5" Text="3"/>
				<Button x:Name="btnCreatePuzzle" Content="Створити пазл"/>
			</StackPanel>
			<ItemsControl x:Name="cPazzelArea">
				
			</ItemsControl>

		</StackPanel>

    </Grid>
</Window>
