<Window x:Class="PR3_2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Puzzle Game" Height="600" Width="800"
        Closing="Window_Closing" 
        Loaded="Window_Loaded">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Оберіть зображення" Command="{Binding SelectImageCommand}" Padding="10,5" Margin="0,0,10,0"/>
            <TextBlock Text="Рядки:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox Width="40" Text="{Binding Rows, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0" VerticalContentAlignment="Center"/>
            <TextBlock Text="Колонки:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox Width="40" Text="{Binding Columns, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0" VerticalContentAlignment="Center"/>
            <Button Content="Створити пазл" Command="{Binding CreatePuzzleCommand}" Padding="10,5" Margin="0,0,10,0"/>
            <Button Content="Перемішати" Command="{Binding ShuffleCommand}" Padding="10,5" Margin="0,0,20,0"/>
            <TextBlock Text="{Binding Moves, StringFormat='Кроків: {0}'}" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
        </StackPanel>

        <ItemsControl Grid.Row="1" ItemsSource="{Binding PuzzlePieces}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas x:Name="cPuzzle" Background="WhiteSmoke" ClipToBounds="True"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="Canvas.Left" Value="{Binding X}" />
                    <Setter Property="Canvas.Top" Value="{Binding Y}" />
                    <Setter Property="Panel.ZIndex" Value="{Binding ZIndex}" />
                </Style>
            </ItemsControl.ItemContainerStyle>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="DarkGray" BorderThickness="1" Background="White"
                            MouseDown="Piece_MouseDown" MouseMove="Piece_MouseMove" MouseUp="Piece_MouseUp"
                            Cursor="Hand">
                        <Image Source="{Binding Image}" Width="{Binding Width}" Height="{Binding Height}" Stretch="Fill" />
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</Window>